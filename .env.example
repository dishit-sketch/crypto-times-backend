# ═══════════════════════════════════════════════════════════
# The Crypto Times — Backend Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Django Core ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS — Frontend Origins ────────────────────────────────
# Comma-separated list of allowed frontend URLs
# Development:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (example):
# CORS_ALLOWED_ORIGINS=https://cryptotimes.vercel.app,https://www.thecryptotimes.com

# ── AI Verification ────────────────────────────────────────
# Provider: mock | anthropic | openai
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── News Fetching ──────────────────────────────────────────
FETCH_INTERVAL_MINUTES=5

# ── Images (optional) ──────────────────────────────────────
UNSPLASH_ACCESS_KEY=

# ── Production Database (when not using SQLite) ────────────
DB_NAME=cryptotimes
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432    
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
